using Workerd = import "/workerd/workerd.capnp";

const unitTests :Workerd.Config = (
  services = [
    ( name = "otel-test",
      worker = (
        modules = [
          (name = "worker", esModule = embed "otel-test.js"),
        ],
        compatibilityFlags = ["experimental", "nodejs_compat"],
        streamingTails = ["tail"],
      )
    ),
    ( name = "tail", worker = .tailWorker, ),
  ]
);

const tailWorker :Workerd.Worker = (
  modules = [
    (name = "worker", esModule = embed "otel-instrumentation-test.js"),
    (name = "instrumentation-test-helper", esModule = embed "../instrumentation-test-helper.js")
  ],
  compatibilityFlags = ["experimental", "nodejs_compat"],
);
